# .env.example
#
# SAFE TO COMMIT.
# Copy to ".env" for per-machine configuration.
# ".env" must NOT be committed.

# ----------------------------------
# Common settings
# ----------------------------------

# Default storage location on host
# (used for SQLite DB, artifacts, and optionally Postgres data)
#
# Linux:
#   MLFLOW_DATA_DIR=${HOME}/mlflow-server
#
# Windows:
#   MLFLOW_DATA_DIR=C:/Users/YourName/mlflow-server
#
# MLFLOW_DATA_DIR=${HOME}/mlflow-server/

# MLflow UI / API port
# MLFLOW_PORT=5000


# ----------------------------------
# Network / security (MLflow 3.x)
# ----------------------------------
#
# MLflow 3.x enables security middleware that validates:
#   1) Host headers ("allowed hosts") to protect against DNS rebinding
#   2) CORS origins (browser-only) for cross-site requests
#
# Defaults in docker-compose.yml should be local-only (recommended):
#   MLFLOW_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,mlflow:*
#   MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
#
# To allow access from other machines on your internal network, set BOTH:
# - MLFLOW_ALLOWED_HOSTS: include the hostname/IP you will use in the browser,
#   and prefer :* to allow any port in the Host header.
# - MLFLOW_CORS_ALLOWED_ORIGINS: include the exact browser origin(s) (scheme+host+port).
#
# Examples:
#
# 1) Allow a specific LAN IP (replace 192.168.1.10 with your host LAN IP)
# MLFLOW_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,mlflow:*,192.168.1.10:*
# MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://192.168.1.10:5000
#
# 2) Allow a LAN hostname (replace mlflow.lan with your local DNS name)
# MLFLOW_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,mlflow:*,mlflow.lan:*
# MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://mlflow.lan:5000
#
# 3) DEV-ONLY (least safe): allow all hosts/origins
# MLFLOW_ALLOWED_HOSTS=*
# MLFLOW_CORS_ALLOWED_ORIGINS=*
#
# Uncomment and set as needed:
#
# MLFLOW_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,mlflow:*
# MLFLOW_CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000


# ----------------------------------
# SQLite mode (DEFAULT)
# ----------------------------------
# No config required.
#
# Backend:
#   sqlite:////data/mlflow.db
#
# Server-managed artifacts:
#   file:/data/artifacts
#
# Uncomment only if you want to be explicit:
#
# MLFLOW_BACKEND_URI=sqlite:////data/mlflow.db
# MLFLOW_ARTIFACTS_DESTINATION=file:/data/artifacts
#
# To move EVERYTHING (DB + artifacts) to another drive, set MLFLOW_DATA_DIR.
# Example:
# MLFLOW_DATA_DIR=/mnt/fast-ssd/mlflow-server
#
# To keep DB in MLFLOW_DATA_DIR but place artifacts on another mounted path,
# point the MLflow server to that container-visible path:
# MLFLOW_ARTIFACTS_DESTINATION=file:/data/external-artifacts
#
# If you use a custom local path outside /data, you must also adjust the bind
# mount in docker-compose.yml so the path exists inside the containers.


# ----------------------------------
# PostgreSQL mode (optional)
# ----------------------------------
# Enable with:
#   docker compose --profile pg up -d
#
# Credentials are INTERNAL-ONLY unless Postgres ports are exposed.

# POSTGRES_USER=mlflow
# POSTGRES_PASSWORD=example-placeholder-not-a-secret
# POSTGRES_DB=mlflow
#
# If you enable pg, set backend URI like:
# MLFLOW_BACKEND_URI=postgresql://mlflow:example-placeholder-not-a-secret@postgres:5432/mlflow
#
# Artifacts can still be server-managed on local disk:
# MLFLOW_ARTIFACTS_DESTINATION=file:/data/artifacts
#
# Or use S3/object storage while keeping the server in charge of uploads:
# MLFLOW_ARTIFACTS_DESTINATION=s3://my-bucket/mlflow-artifacts
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# AWS_DEFAULT_REGION=us-east-1
#
# Optional for S3-compatible endpoints (MinIO, etc.):
# MLFLOW_S3_ENDPOINT_URL=https://minio.example.internal


# ----------------------------------
# Automatic GC settings
# ----------------------------------

# How often mlflow gc runs (seconds)
# Default: 86400 (24 hours)
#
# Increase if DB is large and cleanup is expensive.
#
# MLFLOW_GC_INTERVAL_SECONDS=86400
